# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=melhor_das_casas
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# Firebase Storage (opcional)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Admin Configuration
# Lista de emails de administradores (separados por vírgula)
# Apenas estes emails podem acessar o dashboard admin
ADMIN_EMAILS=ghuntter.mendes@hotmail.com

# Lista de CPFs de administradores (separados por vírgula, sem formatação)
# ADMIN_CPFS=12345678901,98765432100


